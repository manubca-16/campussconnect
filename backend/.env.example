# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Certificates
BASE_URL="http://localhost:3000"
CERTIFICATE_STORAGE_PATH="./storage/certificates"
TEMPLATE_STORAGE_PATH="./storage/templates"

# Database
MONGO_URI="mongodb://localhost:27017/campus-connect"

# Auth
JWT_SECRET="your-super-secret-jwt-key"

# Server
PORT=5000

# CORS (comma-separated). Example: https://your-frontend.vercel.app,https://www.yourdomain.com
CORS_ORIGINS="http://localhost:5173"

# Payments
STRIPE_SECRET_KEY="sk_test_..."
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# QR Code
QR_SECRET="your_qr_secret_here"
